package wasm-af:llm@0.1.0;

/// LLM inference capability delivered by the llm-inference provider.
/// Agents import this interface; the provider exports it.
interface inference {
    /// A single message in a conversation.
    record message {
        /// "system", "user", or "assistant"
        role: string,
        content: string,
    }

    record completion-request {
        /// Model identifier (e.g. "gpt-4o", "claude-sonnet-4-6").
        /// The provider may override this based on its routing config.
        model: string,
        messages: list<message>,
        /// Hard upper bound on tokens generated.
        max-tokens: u32,
        /// Sampling temperature in [0.0, 2.0]. None → provider default.
        temperature: option<f32>,
    }

    record completion-response {
        content: string,
        usage: token-usage,
        /// Model actually used (may differ from requested if provider routes).
        model-used: string,
    }

    record token-usage {
        prompt-tokens: u32,
        completion-tokens: u32,
    }

    /// Errors the provider may return.
    record inference-error {
        code: inference-error-code,
        message: string,
    }

    enum inference-error-code {
        /// Upstream model API returned an error.
        upstream-error,
        /// Request was malformed (e.g. empty messages).
        invalid-request,
        /// Rate-limited by the upstream provider.
        rate-limited,
        /// Provider is not configured or link secrets are missing.
        not-configured,
    }

    complete: func(req: completion-request) -> result<completion-response, inference-error>;
}

/// World used by the llm-inference provider to declare what it exports.
world llm-provider {
    export inference;
}

/// World used by agent components that consume LLM inference.
world llm-consumer {
    import inference;
}
