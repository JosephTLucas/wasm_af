package wasmcloud:secrets@0.1.0-draft;

/// Interface for requesting a named secret from the wasmCloud host.
/// The returned `secret` is an opaque resource handle; the value is not
/// loaded into component memory until `reveal::reveal` is called.
interface store {
    variant secrets-error {
        upstream(string),
        io(string),
        not-found,
    }

    /// The decoded secret value — either a UTF-8 string or raw bytes.
    variant secret-value {
        /// Keyword `string` is escaped with `%` in WIT; Rust sees `String`.
        %string(string),
        bytes(list<u8>),
    }

    /// Opaque handle to a secret held by the wasmCloud host.
    resource secret;

    /// Request the secret named `key` from the host's secrets backend.
    /// Returns an opaque handle; the secret value is not yet in memory.
    get: func(key: string) -> result<secret, secrets-error>;
}

/// Interface for revealing the value of a secret held by the host.
interface reveal {
    use store.{secret, secret-value};

    /// Decrypt and return the secret value.  The host zeros its in-memory
    /// copy after this call.  Only call when the plaintext is immediately needed.
    reveal: func(s: borrow<secret>) -> secret-value;
}
