package wasm-af:agent@0.1.0;

/// Shared types used by both the handler and peer interfaces.
/// Extracting these prevents the ambiguous import+export of handler in the agent world.
interface types {
    /// A key-value pair for structured input/output metadata.
    record kv-pair {
        key: string,
        val: string,
    }

    /// Input delivered to an agent by the orchestrator.
    record task-input {
        /// Unique identifier for the parent task.
        task-id: string,
        /// Unique identifier for this step within the task.
        step-id: string,
        /// Opaque payload — interpreted by the agent (JSON-encoded).
        payload: string,
        /// Additional context entries (e.g., accumulated results from prior steps).
        context: list<kv-pair>,
    }

    /// Successful output from an agent.
    record task-output {
        /// Primary result payload (JSON-encoded).
        payload: string,
        /// Optional structured metadata the orchestrator may store alongside the result.
        metadata: list<kv-pair>,
    }

    enum error-code {
        /// The input was malformed or missing required fields.
        invalid-input,
        /// A downstream capability (HTTP, LLM) returned an error.
        capability-failure,
        /// The agent exceeded its allotted time.
        timeout,
        /// Catch-all for unexpected failures.
        internal,
    }

    /// Structured error returned by an agent.
    record agent-error {
        code: error-code,
        message: string,
    }
}

/// The interface every agent component must export.
/// The orchestrator calls `execute` to invoke an agent with a task.
interface handler {
    use types.{task-input, task-output, agent-error};

    /// Execute a task step. Called by the orchestrator.
    execute: func(input: task-input) -> result<task-output, agent-error>;
}

/// The interface an agent imports when the orchestrator has granted it
/// a direct runtime link to a peer agent.  Only present in the component's
/// imports when an explicit direct-comms policy permit has been issued and
/// the orchestrator has called PutLink for the pair.
interface peer {
    use types.{task-input, task-output, agent-error};

    /// Call a directly-linked peer agent.  The peer's step-id is assigned
    /// by the calling agent; the task-id must match the parent task.
    call-peer: func(input: task-input) -> result<task-output, agent-error>;
}

/// Agents export `handler` and import `peer` (only linked when direct comms is permitted).
world agent {
    import types;
    import peer;
    export handler;
}
